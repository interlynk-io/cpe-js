{
  "name": "@interlynk/cpe-js",
  "version": "0.1.0",
  "description": "CPE 2.3 library: parse, encode, validate, and match Common Platform Enumeration names per NIST specifications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cpe",
    "common-platform-enumeration",
    "sbom",
    "vulnerability",
    "nist",
    "security"
  ],
  "author": "Interlynk.io (https://interlynk.io)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/interlynk-io/cpe-js.git"
  },
  "homepage": "https://github.com/interlynk-io/cpe-js#readme",
  "bugs": {
    "url": "https://github.com/interlynk-io/cpe-js/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
